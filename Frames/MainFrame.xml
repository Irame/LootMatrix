<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <Script file="MainFrame.lua" />

    <Frame name="MPLM_MainFrame" parent="UIParent" inherits="PortraitFrameFlatTemplate, TabSystemOwnerTemplate"
        mixin="MPLM_MainFrameMixin" enableMouse="true" movable="true" clampedToScreen="true"
        hidden="true" resizable="true" frameStrata="DIALOG">
        <Size x="1100" y="670" />
        <Anchors>
            <Anchor point="CENTER" relativePoint="CENTER" relativeTo="$parent" />
        </Anchors>
        <Frames>
            <DropdownButton parentKey="Stat1Search" inherits="WowStyle1DropdownTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" x="130" y="-35"/>
                </Anchors>
            </DropdownButton>
            <DropdownButton parentKey="Stat2Search" inherits="WowStyle1DropdownTemplate">
                <Anchors>
                    <Anchor point="LEFT" relativeKey="$parent.Stat1Search" relativePoint="RIGHT" x="10"/>
                </Anchors>
            </DropdownButton>
            <Frame parentKey="HideOtherItems" inherits="ResizeCheckButtonTemplate">
                <KeyValues>
                    <KeyValue key="labelFont" value="GameFontNormalMed2" type="string"/>
                    <KeyValue key="disabledLabelFont" value="GameFontDisableMed2" type="string"/>
                </KeyValues>
                <Anchors>
                    <Anchor point="LEFT" relativeKey="$parent.Stat2Search" relativePoint="RIGHT" x="10"/>
                </Anchors>
            </Frame>
            <DropdownButton parentKey="SlotSelect" inherits="WowStyle1DropdownTemplate">
                <Anchors>
                    <Anchor point="LEFT" relativeKey="$parent.Stat2Search" relativePoint="RIGHT" x="230"/>
                </Anchors>
            </DropdownButton>
            <DropdownButton parentKey="Filter" inherits="WowStyle1DropdownTemplate">
                <Anchors>
                    <Anchor point="TOPRIGHT" x="-40" y="-35" />
                </Anchors>
            </DropdownButton>
            <Button parentKey="ResetFilterButton" inherits="IconButtonTemplate">
                <KeyValues>
                    <KeyValue key="iconAtlas" value="talents-button-undo" type="string"/>
                    <KeyValue key="useAtlasSize" value="true" type="boolean"/>
                    <KeyValue key="useIconAsHighlight" value="true" type="boolean"/>
                    <KeyValue key="tooltipTextColor" value="HIGHLIGHT_FONT_COLOR" type="global"/>
                </KeyValues>
                <Size x="20" y="20"/>
                <Anchors>
                    <Anchor point="LEFT" relativeKey="$parent.Filter" relativePoint="RIGHT" x="5"/>
                </Anchors>
            </Button>
            <Button parentKey="ResizeButton" inherits="PanelResizeButtonTemplate">
                <Anchors>
                    <Anchor point="BOTTOMRIGHT" x="-4" y="4"/>
                </Anchors>
            </Button>
            <Button parentKey="SettingsButton" mixin="MPLM_SettingsButtonMixin">
                <Size x="40" y="40"/>
                <NormalTexture atlas="GM-icon-settings"/>
                <KeyValues>
                    <KeyValue key="atlasKey" value="GM-icon-settings" type="string" />
                </KeyValues>
                <Anchors>
                    <Anchor point="TOPLEFT" x="0" y="-50"/>
                </Anchors>
                <Scripts>
                    <OnLoad method="OnLoad"/>
                    <OnMouseDown method="OnMouseDown"/>
                    <OnMouseUp method="OnMouseUp"/>
                    <OnEnter method="OnEnter"/>
                    <OnLeave method="OnLeave"/>
                    <OnClick method="OnClick"/>
                </Scripts>
            </Button>
            <Frame parentKey="DungeonsFrame" inherits="MPLM_DungeonFrameTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent" relativePoint="TOPLEFT" x="10" y="-90"/>
                    <Anchor point="BOTTOMRIGHT" relativeKey="$parent" relativePoint="BOTTOMRIGHT" x="-10" y="10"/>
                </Anchors>
            </Frame>
            <Frame parentKey="RaidFrame" inherits="MPLM_RaidFrameTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent" relativePoint="TOPLEFT" x="10" y="-90"/>
                    <Anchor point="BOTTOMRIGHT" relativeKey="$parent" relativePoint="BOTTOMRIGHT" x="-10" y="10"/>
                </Anchors>
            </Frame>
			<Frame parentKey="TabSystem" inherits="TabSystemTemplate">
				<KeyValues>
					<KeyValue key="minTabWidth" value="100" type="number"/>
					<KeyValue key="maxTabWidth" value="150" type="number"/>
					<KeyValue key="tabSelectSound" value="SOUNDKIT.UI_CLASS_TALENT_TAB" type="global"/>
				</KeyValues>
				<Anchors>
					<Anchor point="TOPLEFT" relativeKey="$parent" relativePoint="BOTTOMLEFT" x="22" y="2"/>
				</Anchors>
			</Frame>
        </Frames>
        <Layers>
            <Layer level="OVERLAY">
                <FontString text="Stats:" inherits="GameFontNormalMed2">
                    <Anchors>
                        <Anchor point="RIGHT" relativeKey="$parent.Stat1Search" relativePoint="LEFT" x="-10"/>
                    </Anchors>
                    <Scripts>
                        <OnLoad function="MPLM_LocalizeFontString"/>
                    </Scripts>
                </FontString>
            </Layer>
            <Layer level="OVERLAY">
                <FontString text="Slots:" inherits="GameFontNormalMed2">
                    <Anchors>
                        <Anchor point="RIGHT" relativeKey="$parent.SlotSelect" relativePoint="LEFT" x="-10"/>
                    </Anchors>
                    <Scripts>
                        <OnLoad function="MPLM_LocalizeFontString"/>
                    </Scripts>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnLoad method="OnLoad"/>
            <OnShow method="OnShow"/>
            <OnMouseDown>
                self:StartMoving()
            </OnMouseDown>
            <OnMouseUp>
                self:StopMovingOrSizing()
            </OnMouseUp>
            <OnEvent method="OnEvent"/>
        </Scripts>
    </Frame>
</Ui>