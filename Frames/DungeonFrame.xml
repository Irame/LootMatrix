<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <Script file="DungeonFrame.lua" />

    <Frame name="MPLM_DungeonHeaderTemplate" mixin="MPLM_DungeonHeaderMixin" inherits="MPLM_RowHeaderTemplate" virtual="true">
        <Layers>
            <Layer level="OVERLAY">
                <Texture parentKey="Image">
                    <Anchors>
                        <Anchor point="TOPLEFT" y="-5"/>
                        <Anchor point="BOTTOMLEFT"/>
                    </Anchors>
                </Texture>
                <FontString parentKey="Label" inherits="SystemFont_Outline">
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent.Image"/>
                        <Anchor point="RIGHT" relativeKey="$parent.Image"/>
                    </Anchors>
                </FontString>
            </Layer>
            <Layer level="BACKGROUND">
                <Texture parentKey="DungeonHighlight" hidden="true">
                    <Color r="0.96" g="0.83" b="0.25" a="0.1"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" y="-2.5"/>
                        <Anchor point="BOTTOMRIGHT" y="-2.5"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        <Scripts>
            <OnSizeChanged method="OnSizeChanged"/>
        </Scripts>
    </Frame>

    <Frame name="MPLM_DungeonFrameTemplate" mixin="MPLM_DungeonFrameMixin" inherits="MPLM_MatrixFrameTemplate" virtual="true">
        <KeyValues>
            <KeyValue key="rowTemplate" value="MPLM_DungeonHeaderTemplate" type="string"/>
        </KeyValues>
    </Frame>
</Ui>